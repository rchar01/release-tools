#!/usr/bin/env bash
set -euo pipefail

BIN_DIR="$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)"
TOOLKIT_DIR="$(CDPATH='' cd -- "$BIN_DIR/.." && pwd)"

if [[ -x "$TOOLKIT_DIR/release-tools" ]]; then
	exec "$TOOLKIT_DIR/release-tools" "$@"
fi

if command -v go >/dev/null 2>&1 && [[ -f "$TOOLKIT_DIR/go.mod" ]]; then
	mkdir -p "$TOOLKIT_DIR/.tmp/go-build" "$TOOLKIT_DIR/.tmp/go-cache"
	export CGO_ENABLED="${CGO_ENABLED:-0}"
	export GOTMPDIR="${GOTMPDIR:-$TOOLKIT_DIR/.tmp/go-build}"
	export GOCACHE="${GOCACHE:-$TOOLKIT_DIR/.tmp/go-cache}"
	cd "$TOOLKIT_DIR"
	exec go run ./cmd/release-tools "$@"
fi

printf '[ERROR] release-tools binary not found and Go is unavailable for source execution\n' >&2
exit 1
