#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd)"
TMP_DIR="${RELEASE_TMP_DIR:-${ROOT_DIR}/.tmp}/error-tests"
RELEASE_TOOLS_BIN="${RELEASE_TOOLS_BIN:-${ROOT_DIR}/.tmp/release-tools-test}"

if [[ ! -x "$RELEASE_TOOLS_BIN" ]]; then
	mkdir -p "$ROOT_DIR/.tmp/go-build" "$ROOT_DIR/.tmp/go-cache"
	(
		cd "$ROOT_DIR"
		CGO_ENABLED=0 \
			GOTMPDIR="$ROOT_DIR/.tmp/go-build" \
			GOCACHE="$ROOT_DIR/.tmp/go-cache" \
			go build -o "$RELEASE_TOOLS_BIN" ./cmd/release-tools
	)
fi

expect_error() {
	local expected="$1"
	shift
	local output status
	set +e
	output="$({ "$@"; } 2>&1)"
	status=$?
	set -e

	if [[ $status -eq 0 ]]; then
		printf 'expected failure, command succeeded: %s\n' "$*" >&2
		exit 1
	fi

	if [[ "$output" != *"$expected"* ]]; then
		printf 'expected error containing: %s\nactual output:\n%s\n' "$expected" "$output" >&2
		exit 1
	fi
}

rm -rf "$TMP_DIR"
mkdir -p "$TMP_DIR/no-config" "$TMP_DIR/no-tag" "$TMP_DIR/missing-goreleaser" "$TMP_DIR/missing-news" "$TMP_DIR/invalid-forge" "$TMP_DIR/invalid-artifacts" "$TMP_DIR/empty-artifacts" "$TMP_DIR/empty-artifact-entry" "$TMP_DIR/missing-chart-dirs" "$TMP_DIR/missing-chart-yaml" "$TMP_DIR/invalid-helm-version-from" "$TMP_DIR/symlink-chart-dir" "$TMP_DIR/outside-chart"

cat >"$TMP_DIR/no-tag/.release-tools.env" <<'EOF'
RELEASE_PROJECT=demo
RELEASE_OWNER=owner
EOF
git -C "$TMP_DIR/no-tag" init --quiet

cat >"$TMP_DIR/missing-goreleaser/.release-tools.env" <<'EOF'
RELEASE_PROJECT=demo
RELEASE_OWNER=owner
GORELEASER_CONFIG=.goreleaser.yaml
EOF
touch "$TMP_DIR/missing-goreleaser/.goreleaser.yaml"
cp NEWS.md "$TMP_DIR/missing-goreleaser/NEWS.md"

cat >"$TMP_DIR/missing-news/.release-tools.env" <<'EOF'
RELEASE_PROJECT=demo
RELEASE_OWNER=owner
GORELEASER_CONFIG=.goreleaser.yaml
RELEASE_NOTES_MODE=news-md
RELEASE_NOTES_SOURCE=NEWS.md
EOF
touch "$TMP_DIR/missing-news/.goreleaser.yaml"

cat >"$TMP_DIR/invalid-forge/.release-tools.env" <<'EOF'
RELEASE_PROJECT=demo
RELEASE_FORGE=svn
RELEASE_OWNER=owner
EOF

cat >"$TMP_DIR/invalid-artifacts/.release-tools.env" <<'EOF'
RELEASE_PROJECT=demo
RELEASE_OWNER=owner
RELEASE_ARTIFACTS=containers
EOF

cat >"$TMP_DIR/empty-artifacts/.release-tools.env" <<'EOF'
RELEASE_PROJECT=demo
RELEASE_OWNER=owner
RELEASE_ARTIFACTS=
EOF

cat >"$TMP_DIR/empty-artifact-entry/.release-tools.env" <<'EOF'
RELEASE_PROJECT=demo
RELEASE_OWNER=owner
RELEASE_ARTIFACTS=binaries,,charts
EOF

cat >"$TMP_DIR/missing-chart-dirs/.release-tools.env" <<'EOF'
RELEASE_PROJECT=demo
RELEASE_OWNER=owner
RELEASE_ARTIFACTS=charts
EOF

cat >"$TMP_DIR/missing-chart-yaml/.release-tools.env" <<'EOF'
RELEASE_PROJECT=demo
RELEASE_OWNER=owner
RELEASE_ARTIFACTS=charts
RELEASE_HELM_CHART_DIRS=charts/demo
EOF
mkdir -p "$TMP_DIR/missing-chart-yaml/charts/demo"

cat >"$TMP_DIR/invalid-helm-version-from/.release-tools.env" <<'EOF'
RELEASE_PROJECT=demo
RELEASE_OWNER=owner
RELEASE_ARTIFACTS=charts
RELEASE_HELM_CHART_DIRS=charts/demo
RELEASE_HELM_VERSION_FROM=chart
EOF

cat >"$TMP_DIR/symlink-chart-dir/.release-tools.env" <<'EOF'
RELEASE_PROJECT=demo
RELEASE_OWNER=owner
RELEASE_ARTIFACTS=charts
RELEASE_HELM_CHART_DIRS=charts/linked
EOF
mkdir -p "$TMP_DIR/symlink-chart-dir/charts" "$TMP_DIR/outside-chart"
cat >"$TMP_DIR/outside-chart/Chart.yaml" <<'EOF'
apiVersion: v2
name: outside
version: 0.0.0
EOF
ln -s "$TMP_DIR/outside-chart" "$TMP_DIR/symlink-chart-dir/charts/linked"

expect_error '[ERROR] RELEASE_PROJECT is required' \
	env -u RELEASE_PROJECT -u RELEASE_OWNER -u RELEASE_REPO RELEASE_REPO_ROOT="$TMP_DIR/no-config" "$RELEASE_TOOLS_BIN" check

expect_error '[ERROR] RELEASE_OWNER is required' \
	env -u RELEASE_OWNER -u RELEASE_REPO RELEASE_PROJECT=demo RELEASE_REPO_ROOT="$TMP_DIR/no-config" "$RELEASE_TOOLS_BIN" check

expect_error '[ERROR] VERSION is required, e.g. publish-tag v1.2.3' \
	env RELEASE_REPO_ROOT="$ROOT_DIR" "$RELEASE_TOOLS_BIN" publish-tag

expect_error '[ERROR] GORELEASER_BIN is not executable: /missing/goreleaser' \
	env RELEASE_REPO_ROOT="$TMP_DIR/missing-goreleaser" GORELEASER_BIN=/missing/goreleaser "$RELEASE_TOOLS_BIN" doctor

expect_error '[ERROR] release notes source not found:' \
	env RELEASE_REPO_ROOT="$TMP_DIR/missing-news" GORELEASER_BIN=/bin/true "$RELEASE_TOOLS_BIN" doctor

expect_error '[ERROR] unsupported RELEASE_FORGE: svn' \
	env RELEASE_REPO_ROOT="$TMP_DIR/invalid-forge" GORELEASER_BIN=/bin/true "$RELEASE_TOOLS_BIN" doctor

expect_error '[ERROR] unsupported RELEASE_ARTIFACTS value: containers' \
	env RELEASE_REPO_ROOT="$TMP_DIR/invalid-artifacts" GORELEASER_BIN=/bin/true "$RELEASE_TOOLS_BIN" doctor

expect_error '[ERROR] RELEASE_ARTIFACTS is empty' \
	env RELEASE_REPO_ROOT="$TMP_DIR/empty-artifacts" GORELEASER_BIN=/bin/true "$RELEASE_TOOLS_BIN" doctor

expect_error '[ERROR] RELEASE_ARTIFACTS contains an empty entry' \
	env RELEASE_REPO_ROOT="$TMP_DIR/empty-artifact-entry" GORELEASER_BIN=/bin/true "$RELEASE_TOOLS_BIN" doctor

expect_error '[ERROR] RELEASE_HELM_CHART_DIRS is required when RELEASE_ARTIFACTS includes charts' \
	env RELEASE_REPO_ROOT="$TMP_DIR/missing-chart-dirs" GORELEASER_BIN=/bin/true "$RELEASE_TOOLS_BIN" doctor

expect_error '[ERROR] Helm Chart.yaml not found:' \
	env RELEASE_REPO_ROOT="$TMP_DIR/missing-chart-yaml" GORELEASER_BIN=/bin/true "$RELEASE_TOOLS_BIN" doctor

expect_error '[ERROR] unsupported RELEASE_HELM_VERSION_FROM: chart' \
	env RELEASE_REPO_ROOT="$TMP_DIR/invalid-helm-version-from" GORELEASER_BIN=/bin/true "$RELEASE_TOOLS_BIN" doctor

expect_error '[ERROR] Helm chart dir must stay inside repository:' \
	env RELEASE_REPO_ROOT="$TMP_DIR/symlink-chart-dir" GORELEASER_BIN=/bin/true "$RELEASE_TOOLS_BIN" doctor

expect_error '[ERROR] VERSION is required when the current commit is not an exact tag' \
	env -u VERSION RELEASE_REPO_ROOT="$TMP_DIR/no-tag" "$RELEASE_TOOLS_BIN" notes

rm -rf "$TMP_DIR"
