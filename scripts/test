#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd)"
cd "$ROOT_DIR"
mkdir -p .tmp/go-build .tmp/go-cache
export CGO_ENABLED="${CGO_ENABLED:-0}"
export GOTMPDIR="${GOTMPDIR:-$ROOT_DIR/.tmp/go-build}"
export GOCACHE="${GOCACHE:-$ROOT_DIR/.tmp/go-cache}"

rm -rf dist
bash -n scripts/*
shellcheck scripts/*
injection_marker="$ROOT_DIR/.tmp/make-version-injection"
rm -f "$injection_marker"
# shellcheck disable=SC2016
make_version_payload='v";touch$${IFS}.tmp/make-version-injection;#'
if VERSION="$make_version_payload" make build >/dev/null 2>&1; then
	:
fi
if [[ -e "$injection_marker" ]]; then
	printf 'Makefile VERSION shell injection created %s\n' "$injection_marker" >&2
	exit 1
fi
if VERSION='v1 -X main.releaseToolsVersion=pwned' make build >/dev/null 2>&1; then
	printf 'Makefile accepted VERSION that smuggles Go linker flags\n' >&2
	exit 1
fi
version_env_log="$ROOT_DIR/.tmp/make-version-env"
version_env_stub="$ROOT_DIR/.tmp/make-release-tools-env-check"
rm -f "$version_env_log"
cat >"$version_env_stub" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
printf '%s\n' "${VERSION-unset}" >"$MAKE_VERSION_ENV_LOG"
EOF
chmod +x "$version_env_stub"
MAKE_VERSION_ENV_LOG="$version_env_log" \
	VERSION=make-version-leak \
	RELEASE_TOOLS="$version_env_stub" \
	make check >/dev/null
if [[ "$(<"$version_env_log")" != unset ]]; then
	printf 'Makefile leaked VERSION into release-tools command environment\n' >&2
	exit 1
fi
for ignore_file in .containerignore .dockerignore; do
	for ignored_path in .git/ .tmp/ dist/; do
		if ! grep -qx "$ignored_path" "$ignore_file"; then
			printf '%s does not exclude %s from container build context\n' "$ignore_file" "$ignored_path" >&2
			exit 1
		fi
	done
done
for smoke_script in scripts/test-helm-registries scripts/test-helm-oci-signing scripts/test-helm-provenance; do
	if ! grep -Eq '^[[:space:]]*env -i[[:space:]]*\\$' "$smoke_script"; then
		printf '%s does not isolate release-tools fixture invocation with env -i\n' "$smoke_script" >&2
		exit 1
	fi
	for forbidden_env in \
		'RELEASE_CONFIG_FILE=' \
		'RELEASE_HELM_OCI_PASSWORD=' \
		'RELEASE_HELM_CLASSIC_TOKEN=' \
		'GORELEASER_BIN=' \
		'GITEA_TOKEN=' \
		'GITHUB_TOKEN=' \
		'GITLAB_TOKEN='
	do
		if grep -Eq "^[[:space:]]+$forbidden_env" "$smoke_script"; then
			printf '%s passes ambient-sensitive %s to isolated smoke test\n' "$smoke_script" "$forbidden_env" >&2
			exit 1
		fi
	done
done
if grep -q '/workspace/.tmp/codeberg-smoke-token\|ROOT_DIR/.tmp/codeberg-smoke-token' scripts/test-codeberg-smoke; then
	printf 'Codeberg smoke test stages token inside repository build context\n' >&2
	exit 1
fi
for auth_file in curl-auth.conf netrc; do
	if ! grep -q "install -m 0600 /dev/null \"\$auth_dir/$auth_file\"" scripts/test-codeberg-smoke; then
		printf 'Codeberg smoke test does not create %s with mode 0600\n' "$auth_file" >&2
		exit 1
	fi
done
# shellcheck disable=SC2016
if grep -q '\$test_root/curl-auth.conf\|\$test_root/netrc' scripts/test-codeberg-smoke; then
	printf 'Codeberg smoke test writes token auth files under repo .tmp\n' >&2
	exit 1
fi
smoke_secret_test="$ROOT_DIR/.tmp/codeberg smoke secret test"
rm -rf "$smoke_secret_test"
mkdir -p "$smoke_secret_test/bin" "$smoke_secret_test/tmp"
external_token_dir="$(mktemp -d /tmp/release-tools-codeberg-token-test.XXXXXX)"
cat >"$smoke_secret_test/bin/podman" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
printf 'cmd=%s\n' "${1:-}" >>"$PODMAN_LOG"
for arg in "$@"; do
	printf 'arg=%s\n' "$arg" >>"$PODMAN_LOG"
done
printf 'end\n' >>"$PODMAN_LOG"
EOF
chmod +x "$smoke_secret_test/bin/podman"
printf '%s\n' token >"$external_token_dir/token"
repo_token="$ROOT_DIR/.tmp/repo-codeberg-smoke-token"
printf '%s\n' token >"$repo_token"
set +e
PATH="$smoke_secret_test/bin:$PATH" \
	PODMAN_LOG="$smoke_secret_test/podman.log" \
	CODEBERG_TOKEN_FILE="$repo_token" \
	CODEBERG_USERNAME=test \
	CODEBERG_SMOKE_OWNER=test \
	CODEBERG_SMOKE_REPO=test \
	scripts/test-codeberg-smoke >/dev/null 2>"$smoke_secret_test/repo-token.err"
repo_token_status=$?
set -e
if [[ $repo_token_status -eq 0 ]]; then
	printf 'Codeberg smoke test accepted repo-local token file\n' >&2
	exit 1
fi
if [[ -f "$smoke_secret_test/podman.log" ]]; then
	printf 'Codeberg smoke test invoked podman after repo-local token rejection\n' >&2
	exit 1
fi
if ! grep -q 'must stay outside repository build context' "$smoke_secret_test/repo-token.err"; then
	printf 'Codeberg smoke test did not explain repo-local token rejection\n' >&2
	exit 1
fi
rm -f "$repo_token" "$smoke_secret_test/repo-token.err"
repo_token_link="$ROOT_DIR/.tmp/repo-codeberg-smoke-token-link"
ln -s "$external_token_dir" "$repo_token_link"
set +e
PATH="$smoke_secret_test/bin:$PATH" \
	PODMAN_LOG="$smoke_secret_test/podman.log" \
	CODEBERG_TOKEN_FILE="$repo_token_link/token" \
	CODEBERG_USERNAME=test \
	CODEBERG_SMOKE_OWNER=test \
	CODEBERG_SMOKE_REPO=test \
	scripts/test-codeberg-smoke >/dev/null 2>"$smoke_secret_test/repo-token-link.err"
repo_token_link_status=$?
set -e
if [[ $repo_token_link_status -eq 0 ]]; then
	printf 'Codeberg smoke test accepted repo-local symlink token path\n' >&2
	exit 1
fi
if [[ -f "$smoke_secret_test/podman.log" ]]; then
	printf 'Codeberg smoke test invoked podman after repo-local symlink token rejection\n' >&2
	exit 1
fi
if ! grep -q 'must stay outside repository build context' "$smoke_secret_test/repo-token-link.err"; then
	printf 'Codeberg smoke test did not explain repo-local symlink token rejection\n' >&2
	exit 1
fi
rm -f "$repo_token_link" "$smoke_secret_test/repo-token-link.err"
PATH="$smoke_secret_test/bin:$PATH" \
	PODMAN_LOG="$smoke_secret_test/podman.log" \
	TMPDIR="$smoke_secret_test/tmp" \
	CODEBERG_TOKEN_FILE="$external_token_dir/token" \
	CODEBERG_USERNAME=test \
	CODEBERG_SMOKE_OWNER=test \
	CODEBERG_SMOKE_REPO=test \
	scripts/test-codeberg-smoke
if grep -q "$ROOT_DIR/.tmp/codeberg-smoke-token\|/workspace/.tmp/codeberg-smoke-token" "$smoke_secret_test/podman.log"; then
	printf 'Codeberg smoke token path entered podman build or run args under repo .tmp\n' >&2
	exit 1
fi
if grep -q "$smoke_secret_test/tmp" "$smoke_secret_test/podman.log"; then
	printf 'Codeberg smoke token was staged under repo-local TMPDIR\n' >&2
	exit 1
fi
if ! grep -Eq -- '^arg=.*/release-tools-codeberg-smoke\.[^:]*:/run/release-tools-secrets:ro,Z$' "$smoke_secret_test/podman.log"; then
	printf 'Codeberg smoke token was not mounted as a run-only read-only secret volume\n' >&2
	exit 1
fi
if ! grep -Fxq 'arg=CODEBERG_TOKEN_FILE=/run/release-tools-secrets/codeberg-smoke-token' "$smoke_secret_test/podman.log"; then
	printf 'Codeberg smoke container did not use mounted secret token path\n' >&2
	exit 1
fi
rm -f "$smoke_secret_test/podman.log"
PATH="$smoke_secret_test/bin:$PATH" \
	PODMAN_LOG="$smoke_secret_test/podman.log" \
	TMPDIR="$smoke_secret_test/missing" \
	CODEBERG_TOKEN_FILE="$external_token_dir/token" \
	CODEBERG_USERNAME=test \
	CODEBERG_SMOKE_OWNER=test \
	CODEBERG_SMOKE_REPO=test \
	scripts/test-codeberg-smoke
if ! grep -Eq -- '^arg=/tmp/release-tools-codeberg-smoke\.[^:]*:/run/release-tools-secrets:ro,Z$' "$smoke_secret_test/podman.log"; then
	printf 'Codeberg smoke token did not fall back to /tmp for invalid TMPDIR\n' >&2
	exit 1
fi
rm -f "$smoke_secret_test/podman.log"
linked_root="$smoke_secret_test/linked repo"
ln -s "$ROOT_DIR" "$linked_root"
mkdir -p "$linked_root/.tmp/secret-tmp"
PATH="$smoke_secret_test/bin:$PATH" \
	PODMAN_LOG="$smoke_secret_test/podman.log" \
	TMPDIR="$linked_root/.tmp/secret-tmp" \
	CODEBERG_TOKEN_FILE="$external_token_dir/token" \
	CODEBERG_USERNAME=test \
	CODEBERG_SMOKE_OWNER=test \
	CODEBERG_SMOKE_REPO=test \
	"$linked_root/scripts/test-codeberg-smoke"
if grep -q "$ROOT_DIR/.tmp/secret-tmp\|$linked_root/.tmp/secret-tmp" "$smoke_secret_test/podman.log"; then
	printf 'Codeberg smoke token was staged under symlinked repo-local TMPDIR\n' >&2
	exit 1
fi
if ! grep -Eq -- '^arg=/tmp/release-tools-codeberg-smoke\.[^:]*:/run/release-tools-secrets:ro,Z$' "$smoke_secret_test/podman.log"; then
	printf 'Codeberg smoke token did not fall back to /tmp for symlinked repo TMPDIR\n' >&2
	exit 1
fi
rm -rf "$ROOT_DIR/.tmp/secret-tmp"
rm -rf "$smoke_secret_test"
rm -rf "$external_token_dir"
go test ./...
go build -o .tmp/release-tools-test ./cmd/release-tools
.tmp/release-tools-test help >/dev/null
.tmp/release-tools-test version >/dev/null
.tmp/release-tools-test completion bash >/dev/null
.tmp/release-tools-test completion zsh >/dev/null
.tmp/release-tools-test completion fish >/dev/null
.tmp/release-tools-test completion powershell >/dev/null
.tmp/release-tools-test __complete "" >/dev/null 2>/dev/null

helm_env_test="$ROOT_DIR/.tmp/helm-env-isolation-test"
rm -rf "$helm_env_test"
mkdir -p "$helm_env_test/bin" "$helm_env_test/home" "$helm_env_test/repo/charts/demo"
helm_env_log="$helm_env_test/helm.log"
cat >"$helm_env_test/bin/helm" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
printf '%s\n' "$*" >>"$HELM_ENV_ISOLATION_LOG"
case "${1:-}" in
package)
	version=""
	destination=""
	while [[ $# -gt 0 ]]; do
		case "$1" in
		--version) version="$2"; shift 2 ;;
		--destination) destination="$2"; shift 2 ;;
		*) shift ;;
		esac
	done
	mkdir -p "$destination"
	printf 'fixture chart\n' >"$destination/demo-$version.tgz"
	;;
push)
	printf 'Pushed: %s/demo:0.3.0\n' "$3"
	printf 'Digest: sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\n'
	;;
esac
EOF
chmod +x "$helm_env_test/bin/helm"
cat >"$helm_env_test/bin/goreleaser" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
if [[ "${1:-}" == --version ]]; then
	printf 'goreleaser stub\n'
fi
exit 0
EOF
chmod +x "$helm_env_test/bin/goreleaser"
cat >"$helm_env_test/repo/.goreleaser.yaml" <<'EOF'
version: 2
EOF
cat >"$helm_env_test/repo/charts/demo/Chart.yaml" <<'EOF'
apiVersion: v2
name: demo
version: 0.0.0
EOF
cat >"$helm_env_test/repo/NEWS.md" <<'EOF'
# News

## v0.3.0 - 2026-07-10

- Helm environment isolation fixture.
EOF
cat >"$helm_env_test/repo/.release-tools.env" <<EOF
RELEASE_PROJECT=demo
RELEASE_FORGE=codeberg
RELEASE_OWNER=owner
RELEASE_REPO=demo
RELEASE_ARTIFACTS=charts
RELEASE_HELM_CHART_DIRS=charts/demo
RELEASE_HELM_VERSION_FROM=tag
RELEASE_HELM_APP_VERSION_FROM=tag
RELEASE_HELM_OCI_REPOSITORY=oci://fixture.invalid/owner/charts
RELEASE_NOTES_MODE=news-md
RELEASE_NOTES_SOURCE=NEWS.md
RELEASE_BODY_MODE=none
GORELEASER_BIN=$helm_env_test/bin/goreleaser
EOF
git -C "$helm_env_test/repo" init --quiet
git -C "$helm_env_test/repo" config user.email test@example.invalid
git -C "$helm_env_test/repo" config user.name 'Test User'
git -C "$helm_env_test/repo" add .goreleaser.yaml .release-tools.env NEWS.md charts/demo/Chart.yaml
git -C "$helm_env_test/repo" commit --quiet -m 'helm env isolation fixture'
git -C "$helm_env_test/repo" tag v0.3.0
RELEASE_CONFIG_FILE=/missing-hostile.env \
	RELEASE_HELM_OCI_REPOSITORY=oci://hostile.invalid/owner/charts \
	RELEASE_HELM_OCI_USERNAME=hostile-user \
	RELEASE_HELM_OCI_PASSWORD=hostile-password \
	GORELEASER_BIN=/missing-hostile-goreleaser \
	GITEA_TOKEN=hostile-forge-token \
	env -i \
	HELM_ENV_ISOLATION_LOG="$helm_env_log" \
	HOME="$helm_env_test/home" \
	PATH="$helm_env_test/bin:$PATH" \
	RELEASE_REPO_ROOT="$helm_env_test/repo" \
	RELEASE_TOKEN=fixture-forge-token \
	"$ROOT_DIR/.tmp/release-tools-test" publish-tag v0.3.0 >/dev/null
if grep -q 'hostile' "$helm_env_log"; then
	printf 'isolated Helm smoke fixture inherited hostile release environment\n' >&2
	exit 1
fi
if ! grep -q 'fixture.invalid' "$helm_env_log"; then
	printf 'isolated Helm smoke fixture did not use fixture OCI repository\n' >&2
	exit 1
fi
rm -rf "$helm_env_test"

scripts/test-errors
.tmp/release-tools-test doctor >/dev/null
.tmp/release-tools-test check >/dev/null
.tmp/release-tools-test snapshot >/dev/null
for target in linux_amd64_v1 darwin_amd64_v1; do
	release_binary="dist/release-tools_${target}/release-tools"
	if [[ ! -f "$release_binary" ]]; then
		printf 'missing snapshot binary for %s\n' "$target" >&2
		exit 1
	fi
done
for asset in linux_amd64 darwin_amd64; do
	if ! grep -q "release-tools_.*_${asset}" dist/artifacts.json; then
		printf 'missing upload artifact name for %s\n' "$asset" >&2
		exit 1
	fi
done
if grep -q 'arm64' dist/artifacts.json; then
	printf 'unexpected arm64 release artifact in dist/artifacts.json\n' >&2
	exit 1
fi
case "$(uname -s):$(uname -m)" in
Linux:x86_64|Linux:amd64) release_binary="dist/release-tools_linux_amd64_v1/release-tools" ;;
Darwin:x86_64|Darwin:amd64) release_binary="dist/release-tools_darwin_amd64_v1/release-tools" ;;
*) release_binary="" ;;
esac
if [[ -n "$release_binary" ]]; then
	install_bin="$ROOT_DIR/.tmp/install-bin/release-tools"
	mkdir -p "$(dirname -- "$install_bin")"
	cp "$release_binary" "$install_bin"
	chmod +x "$install_bin"
	"$install_bin" help >/dev/null
	"$install_bin" --version >/dev/null
	"$install_bin" completion bash >/dev/null
fi
notes_file="$(.tmp/release-tools-test notes v3.0.0)"
grep -q 'RELEASE_FORGE' "$notes_file"
rm -f "$notes_file"

chart_test_dir="$ROOT_DIR/.tmp/chart-test"
stub_bin="$chart_test_dir/bin"
rm -rf "$chart_test_dir"
mkdir -p "$stub_bin" "$chart_test_dir/charts/demo"
cat >"$stub_bin/goreleaser" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
printf 'goreleaser-pwd %s\n' "$PWD" >>"$GORELEASER_LOG"
printf 'goreleaser %s\n' "$*" >>"$GORELEASER_LOG"
EOF
cat >"$stub_bin/helm" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
printf 'helm-pwd %s\n' "$PWD" >>"$HELM_LOG"
printf 'helm %s\n' "$*" >>"$HELM_LOG"
if [[ "${1:-}" == package ]]; then
  chart="${2:?missing chart}"
  version=""
  destination=""
  signed=0
  shift 2
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --version) version="${2:?missing version}"; shift 2 ;;
      --app-version) shift 2 ;;
      --destination) destination="${2:?missing destination}"; shift 2 ;;
      --sign) signed=1; shift ;;
      *) shift ;;
    esac
  done
  mkdir -p "$destination"
  touch "$destination/$(basename -- "$chart")-$version.tgz"
  if [[ $signed -eq 1 ]]; then
    touch "$destination/$(basename -- "$chart")-$version.tgz.prov"
  fi
fi
EOF
chmod +x "$stub_bin/goreleaser" "$stub_bin/helm"
cat >"$chart_test_dir/.goreleaser.yaml" <<'EOF'
version: 2
EOF
cat >"$chart_test_dir/charts/demo/Chart.yaml" <<'EOF'
apiVersion: v2
name: demo
version: 0.0.0
EOF
cat >"$chart_test_dir/release-keyring.gpg" <<'EOF'
fake keyring
EOF
cat >"$chart_test_dir/NEWS.md" <<'EOF'
# News

## v1.2.3 - 2026-07-02

- test chart publish sequencing
EOF
cat >"$chart_test_dir/.release-tools.env" <<EOF
RELEASE_PROJECT=demo
RELEASE_OWNER=owner
RELEASE_ARTIFACTS=charts
RELEASE_HELM_CHART_DIRS=charts/demo
RELEASE_HELM_OCI_REPOSITORY=oci://registry.example/charts
RELEASE_HELM_PROVENANCE=true
RELEASE_HELM_GPG_KEY=maintainer@example.org
RELEASE_HELM_GPG_KEYRING=release-keyring.gpg
RELEASE_NOTES_MODE=news-md
RELEASE_NOTES_SOURCE=NEWS.md
RELEASE_BODY_MODE=none
GORELEASER_BIN=$stub_bin/goreleaser
EOF
git -C "$chart_test_dir" init --quiet
git -C "$chart_test_dir" config user.email test@example.invalid
git -C "$chart_test_dir" config user.name 'Test User'
git -C "$chart_test_dir" add .goreleaser.yaml .release-tools.env NEWS.md release-keyring.gpg charts/demo/Chart.yaml
git -C "$chart_test_dir" commit --quiet -m 'chart release fixture'
git -C "$chart_test_dir" tag v1.2.3
HELM_LOG="$chart_test_dir/helm.log" \
  GORELEASER_LOG="$chart_test_dir/goreleaser.log" \
  PATH="$stub_bin:$PATH" \
  RELEASE_REPO_ROOT="$chart_test_dir" \
  .tmp/release-tools-test check >/dev/null
grep -q 'helm dependency update --skip-refresh charts/demo' "$chart_test_dir/helm.log"
grep -q 'helm lint charts/demo' "$chart_test_dir/helm.log"
HELM_LOG="$chart_test_dir/helm.log" \
  GORELEASER_LOG="$chart_test_dir/goreleaser.log" \
  PATH="$stub_bin:$PATH" \
  RELEASE_REPO_ROOT="$chart_test_dir" \
  VERSION=v1.2.3 \
  .tmp/release-tools-test snapshot >/dev/null
grep -q 'helm package charts/demo --version 1.2.3 --app-version 1.2.3 --destination dist/charts --sign --key maintainer@example.org --keyring .*/release-keyring.gpg' "$chart_test_dir/helm.log"
test -f "$chart_test_dir/dist/charts/demo-1.2.3.tgz"
test -f "$chart_test_dir/dist/charts/demo-1.2.3.tgz.prov"
test -f "$chart_test_dir/dist/release-manifest.json"
grep -q '"tag": "v1.2.3"' "$chart_test_dir/dist/release-manifest.json"
grep -q '"path": "dist/charts/demo-1.2.3.tgz"' "$chart_test_dir/dist/release-manifest.json"
grep -q '"provenance_path": "dist/charts/demo-1.2.3.tgz.prov"' "$chart_test_dir/dist/release-manifest.json"
rm -f "$chart_test_dir/helm.log" "$chart_test_dir/goreleaser.log"
rm -f "$chart_test_dir/dist/release-manifest.json"
HELM_LOG="$chart_test_dir/helm.log" \
  GORELEASER_LOG="$chart_test_dir/goreleaser.log" \
  PATH="$stub_bin:$PATH" \
  RELEASE_REPO_ROOT="$chart_test_dir" \
  RELEASE_TOKEN=token \
  RELEASE_HELM_OCI_USERNAME=robot \
  RELEASE_HELM_OCI_PASSWORD=registry-token \
  VERSION=v1.2.3 \
  .tmp/release-tools-test publish >/dev/null
grep -q 'helm package charts/demo --version 1.2.3 --app-version 1.2.3 --destination .*/release-tools-helm-charts-v1.2.3-.* --sign --key maintainer@example.org --keyring .*/release-keyring.gpg' "$chart_test_dir/helm.log"
grep -q 'helm registry login registry.example --username robot --password-stdin --registry-config' "$chart_test_dir/helm.log"
grep -q 'helm push .*/demo-1.2.3.tgz oci://registry.example/charts' "$chart_test_dir/helm.log"
grep -q 'goreleaser --config .goreleaser.yaml release --clean --release-notes' "$chart_test_dir/goreleaser.log"
grep -q '"oci_ref": "oci://registry.example/charts/demo:1.2.3"' "$chart_test_dir/dist/release-manifest.json"
grep -q '"provenance_path": "dist/charts/demo-1.2.3.tgz.prov"' "$chart_test_dir/dist/release-manifest.json"
rm -f "$chart_test_dir/helm.log" "$chart_test_dir/goreleaser.log"
HELM_LOG="$chart_test_dir/helm.log" \
  GORELEASER_LOG="$chart_test_dir/goreleaser.log" \
  PATH="$stub_bin:$PATH" \
  RELEASE_REPO_ROOT="$chart_test_dir" \
  RELEASE_TOKEN=token \
  RELEASE_HELM_OCI_USERNAME=robot \
  RELEASE_HELM_OCI_PASSWORD=registry-token \
  .tmp/release-tools-test publish-tag v1.2.3 >/dev/null
grep -q 'helm package charts/demo --version 1.2.3 --app-version 1.2.3 --destination .*/release-tools-helm-charts-v1.2.3-.* --sign --key maintainer@example.org --keyring .*/release-keyring.gpg' "$chart_test_dir/helm.log"
grep -q 'helm registry login registry.example --username robot --password-stdin --registry-config' "$chart_test_dir/helm.log"
grep -q 'helm push .*/demo-1.2.3.tgz oci://registry.example/charts' "$chart_test_dir/helm.log"
grep -q "helm-pwd $chart_test_dir/.tmp/release-v1.2.3" "$chart_test_dir/helm.log"
grep -q "goreleaser-pwd $chart_test_dir/.tmp/release-v1.2.3" "$chart_test_dir/goreleaser.log"
test -f "$chart_test_dir/dist/release-manifest.json"
grep -q '"oci_ref": "oci://registry.example/charts/demo:1.2.3"' "$chart_test_dir/dist/release-manifest.json"
grep -q '"path": "dist/charts/demo-1.2.3.tgz"' "$chart_test_dir/dist/release-manifest.json"
grep -q '"provenance_path": "dist/charts/demo-1.2.3.tgz.prov"' "$chart_test_dir/dist/release-manifest.json"
test -f "$chart_test_dir/dist/charts/demo-1.2.3.tgz"
test -f "$chart_test_dir/dist/charts/demo-1.2.3.tgz.prov"
rm -rf "$chart_test_dir"

rm -f .tmp/release-tools-test
rmdir .tmp 2>/dev/null || true
rm -rf dist
