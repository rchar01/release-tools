#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd)"
cd "$ROOT_DIR"

PODMAN="${PODMAN:-podman}"
ZOT_IMAGE="${ZOT_IMAGE:-ghcr.io/project-zot/zot-minimal:v2.1.18}"
CHARTMUSEUM_IMAGE="${CHARTMUSEUM_IMAGE:-ghcr.io/helm/chartmuseum:v0.16.3}"

for tool in "$PODMAN" curl git go helm openssl; do
	if ! command -v "$tool" >/dev/null 2>&1; then
		printf 'required tool not found: %s\n' "$tool" >&2
		exit 1
	fi
done

test_root="$ROOT_DIR/.tmp/helm-registry-test"
repo_dir="$test_root/repo"
bin_dir="$test_root/bin"
pull_dir="$test_root/pull"
tls_dir="$test_root/tls"
release_tools_bin="$bin_dir/release-tools"
zot_container="release-tools-zot-$$"
chartmuseum_container="release-tools-chartmuseum-$$"
classic_user="robot"
classic_token="classic-token"
tag="v0.1.$(date +%s)"
version="${tag#v}"

cleanup() {
	"$PODMAN" rm -f "$zot_container" "$chartmuseum_container" >/dev/null 2>&1 || true
}
trap cleanup EXIT

wait_for_http() {
	url="$1"
	shift
	for ((attempt = 1; attempt <= 60; attempt++)); do
		if curl -fsS "$@" "$url" >/dev/null 2>&1; then
			return 0
		fi
		sleep 1
	done
	printf 'timed out waiting for %s\n' "$url" >&2
	return 1
}

rm -rf "$test_root"
mkdir -p "$bin_dir" "$repo_dir/charts/demo" "$pull_dir" "$tls_dir" "$ROOT_DIR/.tmp/go-build" "$ROOT_DIR/.tmp/go-cache"

openssl req -x509 -newkey rsa:2048 -nodes -sha256 -days 1 \
	-subj "/CN=127.0.0.1" \
	-addext "subjectAltName=IP:127.0.0.1" \
	-keyout "$tls_dir/chartmuseum.key" \
	-out "$tls_dir/chartmuseum.crt" >/dev/null 2>&1

CGO_ENABLED=0 \
	GOTMPDIR="$ROOT_DIR/.tmp/go-build" \
	GOCACHE="$ROOT_DIR/.tmp/go-cache" \
	go build -o "$release_tools_bin" ./cmd/release-tools

"$PODMAN" run --detach --name "$zot_container" \
	--publish 127.0.0.1::5000 \
	"$ZOT_IMAGE" >/dev/null
zot_port_output="$($PODMAN port "$zot_container" 5000/tcp)"
zot_port="${zot_port_output##*:}"
wait_for_http "http://127.0.0.1:$zot_port/v2/"

"$PODMAN" run --detach --name "$chartmuseum_container" \
	--publish 127.0.0.1::8080 \
	--volume "$tls_dir:/certs:ro,Z" \
	-e PORT=8080 \
	-e STORAGE=local \
	-e STORAGE_LOCAL_ROOTDIR=/tmp/charts \
	-e BASIC_AUTH_USER="$classic_user" \
	-e BASIC_AUTH_PASS="$classic_token" \
	-e AUTH_ANONYMOUS_GET=1 \
	-e TLS_CERT=/certs/chartmuseum.crt \
	-e TLS_KEY=/certs/chartmuseum.key \
	"$CHARTMUSEUM_IMAGE" >/dev/null
chartmuseum_port_output="$($PODMAN port "$chartmuseum_container" 8080/tcp)"
chartmuseum_port="${chartmuseum_port_output##*:}"
wait_for_http "https://127.0.0.1:$chartmuseum_port/health" --cacert "$tls_dir/chartmuseum.crt"

cat >"$bin_dir/goreleaser" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
if [[ "${1:-}" == --version ]]; then
	printf 'goreleaser stub\n'
	exit 0
fi
exit 0
EOF
chmod +x "$bin_dir/goreleaser"

cat >"$repo_dir/.goreleaser.yaml" <<'EOF'
version: 2
EOF
cat >"$repo_dir/charts/demo/Chart.yaml" <<'EOF'
apiVersion: v2
name: demo
version: 0.0.0
appVersion: "0.0.0"
EOF
cat >"$repo_dir/NEWS.md" <<EOF
# News

## $tag - 2026-07-08

- Smoke test Helm registry publishing.
EOF
printf '%s\n' "$classic_token" >"$repo_dir/classic-token"
cat >"$repo_dir/.release-tools.env" <<EOF
RELEASE_PROJECT=demo
RELEASE_FORGE=codeberg
RELEASE_OWNER=owner
RELEASE_REPO=demo
RELEASE_ARTIFACTS=charts
RELEASE_HELM_CHART_DIRS=charts/demo
RELEASE_HELM_VERSION_FROM=tag
RELEASE_HELM_APP_VERSION_FROM=tag
RELEASE_HELM_OCI_REPOSITORY=oci://localhost:$zot_port/owner/charts
RELEASE_HELM_OCI_PLAIN_HTTP=1
RELEASE_HELM_CLASSIC_URL=https://127.0.0.1:$chartmuseum_port
RELEASE_HELM_CLASSIC_USERNAME=$classic_user
RELEASE_HELM_CLASSIC_TOKEN_FILE=$repo_dir/classic-token
RELEASE_NOTES_MODE=news-md
RELEASE_NOTES_SOURCE=NEWS.md
RELEASE_BODY_MODE=none
GORELEASER_BIN=$bin_dir/goreleaser
EOF

git -C "$repo_dir" init --quiet
git -C "$repo_dir" config user.email test@example.invalid
git -C "$repo_dir" config user.name 'Test User'
git -C "$repo_dir" add .goreleaser.yaml .release-tools.env NEWS.md charts/demo/Chart.yaml classic-token
git -C "$repo_dir" commit --quiet -m 'chart registry smoke fixture'
git -C "$repo_dir" tag "$tag"

RELEASE_REPO_ROOT="$repo_dir" \
	SSL_CERT_FILE="$tls_dir/chartmuseum.crt" \
	RELEASE_TOKEN=forge-token \
	"$release_tools_bin" publish-tag "$tag" >/dev/null

HELM_REGISTRY_CONFIG="$test_root/helm-registry.json" \
	helm pull "oci://localhost:$zot_port/owner/charts/demo" \
	--version "$version" \
	--plain-http \
	--destination "$pull_dir" >/dev/null
test -f "$pull_dir/demo-$version.tgz"

curl -fsS --cacert "$tls_dir/chartmuseum.crt" -u "$classic_user:$classic_token" \
	"https://127.0.0.1:$chartmuseum_port/api/charts/demo/$version" \
	| grep -q '"name":"demo"'

printf 'Helm registry smoke test passed for %s\n' "$tag"
