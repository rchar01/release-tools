#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd)"
cd "$ROOT_DIR"

for tool in gpg go helm; do
	if ! command -v "$tool" >/dev/null 2>&1; then
		printf 'required tool not found: %s\n' "$tool" >&2
		exit 1
	fi
done

test_root="$ROOT_DIR/.tmp/helm-provenance-test"
repo_dir="$test_root/repo"
bin_dir="$test_root/bin"
release_tools_bin="$bin_dir/release-tools"
gpg_home="$test_root/gnupg"
gpg_identity="Release Tools Smoke <smoke@example.invalid>"
tag="v0.1.0"
version="${tag#v}"

cleanup() {
	rm -rf "$test_root"
}
trap cleanup EXIT

rm -rf "$test_root"
mkdir -p "$bin_dir" "$repo_dir/charts/demo" "$test_root/home" "$ROOT_DIR/.tmp/go-build" "$ROOT_DIR/.tmp/go-cache"

CGO_ENABLED=0 \
	GOTMPDIR="$ROOT_DIR/.tmp/go-build" \
	GOCACHE="$ROOT_DIR/.tmp/go-cache" \
	go build -o "$release_tools_bin" ./cmd/release-tools

cat >"$bin_dir/goreleaser" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
if [[ "${1:-}" == --version ]]; then
	printf 'goreleaser stub\n'
	exit 0
fi
exit 0
EOF
chmod +x "$bin_dir/goreleaser"

cat >"$repo_dir/.goreleaser.yaml" <<'EOF'
version: 2
EOF
cat >"$repo_dir/charts/demo/Chart.yaml" <<'EOF'
apiVersion: v2
name: demo
version: 0.0.0
EOF

mkdir -p "$gpg_home"
chmod 700 "$gpg_home"
GNUPGHOME="$gpg_home" gpg --batch --pinentry-mode loopback --passphrase '' \
	--quick-generate-key "$gpg_identity" rsa3072 sign 0 >/dev/null
GNUPGHOME="$gpg_home" gpg --batch --pinentry-mode loopback --passphrase '' \
	--export-secret-keys "$gpg_identity" >"$repo_dir/release-keyring.gpg"

cat >"$repo_dir/.release-tools.env" <<EOF
RELEASE_PROJECT=demo
RELEASE_OWNER=owner
RELEASE_ARTIFACTS=charts
RELEASE_HELM_CHART_DIRS=charts/demo
RELEASE_HELM_PROVENANCE=1
RELEASE_HELM_GPG_KEY=$gpg_identity
RELEASE_HELM_GPG_KEYRING=release-keyring.gpg
RELEASE_NOTES_MODE=none
RELEASE_BODY_MODE=none
GORELEASER_BIN=$bin_dir/goreleaser
EOF

env -i \
	GNUPGHOME="$gpg_home" \
	HOME="$test_root/home" \
	PATH="$bin_dir:$PATH" \
	RELEASE_REPO_ROOT="$repo_dir" \
	VERSION="$tag" \
	"$release_tools_bin" snapshot >/dev/null

chart_package="$repo_dir/dist/charts/demo-$version.tgz"
provenance_file="$chart_package.prov"
manifest_file="$repo_dir/dist/release-manifest.json"

test -f "$chart_package"
test -f "$provenance_file"
test -f "$manifest_file"
grep -q '"provenance_path": "dist/charts/demo-0.1.0.tgz.prov"' "$manifest_file"
grep -q '"provenance_sha256":' "$manifest_file"

GNUPGHOME="$gpg_home" helm verify "$chart_package" --keyring "$repo_dir/release-keyring.gpg" >/dev/null
